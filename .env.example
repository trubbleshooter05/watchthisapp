# Copy to `.env.local` for local dev and Python scripts. Do not commit `.env.local`.
# (`generate_new_page.py` + `forge_pagegen.py` read `.env.local` from the repo root.)
# Scheduling: Hermes-only on the Hermes laptop — see `scripts/HERMES-SETUP.txt`.

# --- Optional: Telegram alerts when a wrapped job fails (`scripts/run-with-telegram-alert.sh`) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Minimum for dev + generate_new_page / forge ---
TMDB_API_KEY=
NEXT_PUBLIC_SITE_URL=https://www.movieslike.app

# --- Required for `npm run cron:gsc` / `npm run automation:daily` ---
# Without both lines, GSC-driven daily automation will fail. (TMDB alone is not enough.)
# Never commit the service account JSON. Prefer GSC_SERVICE_ACCOUNT_FILE (absolute path).
# Fallback: placing gsc-service-account.json at repo root is for local dev only.
GSC_SERVICE_ACCOUNT_FILE=/absolute/path/to/gsc-service-account.json
GSC_SITE_URL=sc-domain:movieslike.app

# Later: OpenAI for regenerating data/recommendations (see scripts/week1-bundles.cjs)
OPENAI_API_KEY=

# Week 3+: NextAuth, DB
DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel: production project is `watchthisapp-prod` under team `gregs-projects-ee26af82`.
# After `npx vercel link`, IDs live in `.vercel/project.json` (gitignored). No need to duplicate in .env for Next.js.
