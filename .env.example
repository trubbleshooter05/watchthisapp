# Movie pages load TMDB on each request; use with `npm run dev` or `npm run start`
# (no rebuild required after changing the key).
TMDB_API_KEY=210e61498925ec7e4e3cce23a5301ca8

# Canonical site URL (use www if apex redirects to www—sitemap + GSC stay consistent)
NEXT_PUBLIC_SITE_URL=https://www.movieslike.app

# Later: OpenAI for regenerating data/recommendations (see scripts/week1-bundles.cjs)
OPENAI_API_KEY=

# Search Console automation (service account JSON file path + property)
GSC_SERVICE_ACCOUNT_FILE=/absolute/path/to/service-account.json
# Example values:
# - sc-domain:movieslike.app
# - https://movieslike.app/
GSC_SITE_URL=sc-domain:movieslike.app

# Week 3+: NextAuth, DB
DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
